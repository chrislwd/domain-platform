# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/domain_platform

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Provider selection: mock | namecheap
PROVIDER=mock

# Namecheap (set PROVIDER=namecheap to activate)
# Get credentials at: https://ap.www.namecheap.com/settings/tools/apiaccess/
PROVIDER_NAMECHEAP_API_KEY=
PROVIDER_NAMECHEAP_API_USER=
PROVIDER_NAMECHEAP_CLIENT_IP=   # Your server's public IP — must be whitelisted in Namecheap
PROVIDER_NAMECHEAP_SANDBOX=true  # false for production

# Default registrant contact (used for domain registration)
REGISTRANT_FIRST_NAME=Domain
REGISTRANT_LAST_NAME=Admin
REGISTRANT_EMAIL=admin@yourdomain.com
REGISTRANT_PHONE=+1.5555555555   # Format: +CountryCode.Number
REGISTRANT_ADDRESS=123 Main St
REGISTRANT_CITY=New York
REGISTRANT_COUNTRY=US            # ISO 3166-1 alpha-2
REGISTRANT_POSTAL_CODE=10001

# USDT Deposit via Hashnut (https://hashnut.io)
# Set HASHNUT_MOCK=true to skip real Hashnut and use local simulation
HASHNUT_MOCK=true
# Get credentials at: https://testnet.hashnut.io (testnet) or https://hashnut.io (prod)
HASHNUT_MCH_NO=          # Merchant number from dashboard
HASHNUT_APP_ID=          # App ID from dashboard
HASHNUT_SECRET_KEY=      # HMAC signing secret
HASHNUT_SANDBOX=true     # false for production
HASHNUT_BASE_URL=https://api.hashnut.io
HASHNUT_SANDBOX_BASE_URL=https://testnet-api.hashnut.io
# The public URL of this API (Hashnut will POST webhooks to it)
API_PUBLIC_URL=https://your-api-domain.com
# Default deposit network: TRC20 | ERC20 | BEP20
DEPOSIT_DEFAULT_CHAIN=TRC20

# Risk Review Thresholds
RISK_ITEM_COUNT_THRESHOLD=50
RISK_AMOUNT_THRESHOLD=5000

# Email (Resend — https://resend.com)
EMAIL_ENABLED=false      # set true in production
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
