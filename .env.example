# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/domain_platform

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Provider selection: mock | namecheap
PROVIDER=mock

# Namecheap (set PROVIDER=namecheap to activate)
# Get credentials at: https://ap.www.namecheap.com/settings/tools/apiaccess/
PROVIDER_NAMECHEAP_API_KEY=
PROVIDER_NAMECHEAP_API_USER=
PROVIDER_NAMECHEAP_CLIENT_IP=   # Your server's public IP — must be whitelisted in Namecheap
PROVIDER_NAMECHEAP_SANDBOX=true  # false for production

# Default registrant contact (used for domain registration)
REGISTRANT_FIRST_NAME=Domain
REGISTRANT_LAST_NAME=Admin
REGISTRANT_EMAIL=admin@yourdomain.com
REGISTRANT_PHONE=+1.5555555555   # Format: +CountryCode.Number
REGISTRANT_ADDRESS=123 Main St
REGISTRANT_CITY=New York
REGISTRANT_COUNTRY=US            # ISO 3166-1 alpha-2
REGISTRANT_POSTAL_CODE=10001

# USDT Deposit (Tron / TronGrid)
TRON_API_KEY=
TRON_NETWORK=shasta   # shasta = testnet, mainnet = mainnet
DEPOSIT_REQUIRED_CONFIRMATIONS=6

# Risk Review Thresholds
RISK_ITEM_COUNT_THRESHOLD=50
RISK_AMOUNT_THRESHOLD=5000

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
