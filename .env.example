# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/domain_platform

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Domain Provider (Namecheap)
PROVIDER_NAMECHEAP_API_KEY=
PROVIDER_NAMECHEAP_API_USER=
PROVIDER_NAMECHEAP_CLIENT_IP=
PROVIDER_NAMECHEAP_SANDBOX=true

# USDT Deposit (Tron / TronGrid)
TRON_API_KEY=
TRON_NETWORK=shasta   # shasta = testnet, mainnet = mainnet
DEPOSIT_REQUIRED_CONFIRMATIONS=6

# Risk Review Thresholds
RISK_ITEM_COUNT_THRESHOLD=50
RISK_AMOUNT_THRESHOLD=5000

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
