    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "bullmq": "^5.7.0",
    "drizzle-orm": "^0.30.9",
    "fastify": "^4.26.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "postgres": "^3.4.4",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "drizzle-kit": "^0.21.2",
    "tsx": "^4.8.2",
    "typescript": "^5.4.0"
  }
